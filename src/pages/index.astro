---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = await getCollection('artigos');

// Lógica de ADS: Agrupando posts por categoria (nome da pasta)
const categorias = posts.reduce((acc, post) => {
    const categoria = post.id.includes('/') ? post.id.split('/')[0] : 'Geral';
    if (!acc[categoria]) acc[categoria] = [];
    acc[categoria].push(post);
    return acc;
}, {});
---

<BaseLayout title="Adytum Wiki | Repositório de Conhecimento">
    <section style="margin-bottom: 4rem;">
        <h1 style="font-size: 3rem; letter-spacing: -0.05em;">Santuário de Conhecimento <span style="color: var(--primary);">Adytum</span></h1>
        <p style="color: var(--text-muted); font-size: 1.2rem;">Documentando a jornada em ADS e automação.</p>
    </section>

    {Object.keys(categorias).map(cat => (
        <div style="margin-bottom: 3rem;">
            <h2 style="text-transform: capitalize; border-bottom: 2px solid var(--primary); display: inline-block; margin-bottom: 1.5rem;">
                {cat}
            </h2>
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
                {categorias[cat].map(post => (
                    <a href={`/artigos/${post.id}`} style="text-decoration: none; color: inherit;">
                        <div class="card">
                            <h3 style="margin: 0 0 10px 0; color: var(--primary);">{post.data.title}</h3>
                            <p style="font-size: 0.9rem; color: var(--text-muted);">{post.data.description}</p>
                        </div>
                    </a>
                ))}
            </div>
        </div>
    ))}
</BaseLayout>
